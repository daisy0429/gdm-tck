#encoding: utf-8

# =============================================================================
# Feature: Movie Scenario - Step 3: WHERE and ORDER BY Filtering
# =============================================================================
# 来源: GDMBASE 电影知识场景教学（初级）第3步
# 目标: 在 MATCH 基础上增加过滤和排序能力
# 前置条件: 需要完整的电影数据集
# =============================================================================

Feature: MovieScenario03 - WHERE and ORDER BY filtering

  Background:
    # 初始化完整的电影数据集
    Given an empty graph
    And having executed:
      """
      CREATE
      (:人物 {姓名:'郭帆', 职业:'导演', 出生年:1980}),
      (:人物 {姓名:'吴京', 职业:'演员', 出生年:1974}),
      (:人物 {姓名:'刘德华', 职业:'演员', 出生年:1961}),
      (:人物 {姓名:'文牧野', 职业:'导演', 出生年:1985}),
      (:人物 {姓名:'徐峥', 职业:'演员', 出生年:1972}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:人物 {姓名:'饺子', 职业:'导演', 出生年:1980}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132}),
      (:电影 {片名:'哪吒之魔童降世', 上映年:2019, 豆瓣评分:8.4, 片长:110}),
      (:类型 {名称:'科幻'}),
      (:类型 {名称:'剧情'}),
      (:类型 {名称:'喜剧'}),
      (:类型 {名称:'动画'}),
      (:国家 {名称:'中国大陆'}),
      (:国家 {名称:'中国香港'}),
      (:奖项 {名称:'金鸡奖最佳故事片', 年份:2023}),
      (:奖项 {名称:'百花奖最佳影片', 年份:2018})
      """
    And having executed:
      """
      MATCH (guo:人物 {姓名:'郭帆'}), (wj:人物 {姓名:'吴京'}), (ldh:人物 {姓名:'刘德华'}),
            (wmy:人物 {姓名:'文牧野'}), (xz:人物 {姓名:'徐峥'}), (jw:人物 {姓名:'姜文'}), (jz:人物 {姓名:'饺子'}),
            (m1:电影 {片名:'流浪地球'}), (m2:电影 {片名:'流浪地球2'}), (m3:电影 {片名:'我不是药神'}),
            (m4:电影 {片名:'让子弹飞'}), (m5:电影 {片名:'哪吒之魔童降世'}),
            (sf:类型 {名称:'科幻'}), (dr:类型 {名称:'剧情'}), (xj:类型 {名称:'喜剧'}), (dh:类型 {名称:'动画'}),
            (cn:国家 {名称:'中国大陆'}), (hk:国家 {名称:'中国香港'}),
            (a1:奖项 {名称:'金鸡奖最佳故事片'}), (a2:奖项 {名称:'百花奖最佳影片'})
      CREATE
      (guo)-[:导演]->(m1),
      (guo)-[:导演]->(m2),
      (wj)-[:参演 {角色:'刘培强'}]->(m1),
      (wj)-[:参演 {角色:'刘培强'}]->(m2),
      (ldh)-[:参演 {角色:'图恒宇'}]->(m2),
      (wmy)-[:导演]->(m3),
      (xz)-[:参演 {角色:'程勇'}]->(m3),
      (jw)-[:导演]->(m4),
      (jw)-[:参演 {角色:'张牧之'}]->(m4),
      (jz)-[:导演]->(m5),
      (m1)-[:属于类型]->(sf),
      (m2)-[:属于类型]->(sf),
      (m3)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(xj),
      (m5)-[:属于类型]->(dh),
      (m1)-[:出品国家]->(cn),
      (m2)-[:出品国家]->(cn),
      (m3)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(hk),
      (m5)-[:出品国家]->(cn),
      (m2)-[:获得奖项]->(a1),
      (m3)-[:获得奖项]->(a2)
      """

  # ---------------------------------------------------------------------------
  # Scenario: 高分电影筛选
  # 评分高于 8.5 的电影
  # ---------------------------------------------------------------------------
  Scenario: [1] Filter high-rated movies
    When executing query:
      """
      MATCH (m:电影)
      WHERE m.豆瓣评分 >= 8.5
      RETURN m.片名 AS 片名, m.豆瓣评分 AS 豆瓣评分
      ORDER BY m.豆瓣评分 DESC
      """
    Then the result should be, in order:
      | 片名       | 豆瓣评分 |
      | 我不是药神 | 9.0      |
      | 让子弹飞   | 8.9      |
      | 流浪地球2  | 8.3      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 近年上映电影筛选
  # 2018 年及以后上映的电影
  # ---------------------------------------------------------------------------
  Scenario: [2] Filter recent movies
    When executing query:
      """
      MATCH (m:电影)
      WHERE m.上映年 >= 2018
      RETURN m.片名 AS 片名, m.上映年 AS 上映年
      ORDER BY m.上映年 DESC, m.片名
      """
    Then the result should be, in order:
      | 片名           | 上映年 |
      | 流浪地球2      | 2023   |
      | 哪吒之魔童降世 | 2019   |
      | 流浪地球       | 2019   |
      | 我不是药神     | 2018   |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 按类型筛选并排序
  # 筛选"科幻"类型电影，按评分从高到低排序
  # 通过 (m)-[:属于类型]->(g) 匹配类型节点，类型体系可扩展
  # ---------------------------------------------------------------------------
  Scenario: [3] Filter movies by genre and sort by rating
    When executing query:
      """
      MATCH (m:电影)-[:属于类型]->(g:类型)
      WHERE g.名称 = '科幻'
      RETURN m.片名 AS 片名, m.豆瓣评分 AS 豆瓣评分, m.片长 AS 片长
      ORDER BY m.豆瓣评分 DESC
      """
    Then the result should be, in order:
      | 片名      | 豆瓣评分 | 片长 |
      | 流浪地球2 | 8.3      | 173  |
      | 流浪地球  | 7.9      | 125  |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 组合条件筛选（类型 + 年份）
  # 必须同时满足"剧情类型"和"2010年以后上映"
  # ---------------------------------------------------------------------------
  Scenario: [4] Filter with combined conditions (genre AND year)
    When executing query:
      """
      MATCH (m:电影)-[:属于类型]->(g:类型)
      WHERE g.名称 = '剧情' AND m.上映年 >= 2010
      RETURN m.片名 AS 片名, m.上映年 AS 上映年, m.豆瓣评分 AS 豆瓣评分
      ORDER BY m.上映年 DESC
      """
    Then the result should be, in order:
      | 片名       | 上映年 | 豆瓣评分 |
      | 我不是药神 | 2018   | 9.0      |
      | 让子弹飞   | 2010   | 8.9      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用 OR 条件筛选
  # 筛选科幻或动画类型的电影
  # ---------------------------------------------------------------------------
  Scenario: [5] Filter with OR condition
    When executing query:
      """
      MATCH (m:电影)-[:属于类型]->(g:类型)
      WHERE g.名称 = '科幻' OR g.名称 = '动画'
      RETURN m.片名 AS 片名, g.名称 AS 类型
      ORDER BY m.片名
      """
    Then the result should be, in order:
      | 片名           | 类型 |
      | 流浪地球       | 科幻 |
      | 流浪地球2      | 科幻 |
      | 哪吒之魔童降世 | 动画 |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用 IN 条件筛选
  # 筛选特定年份上映的电影
  # ---------------------------------------------------------------------------
  Scenario: [6] Filter with IN condition
    When executing query:
      """
      MATCH (m:电影)
      WHERE m.上映年 IN [2019, 2023]
      RETURN m.片名 AS 片名, m.上映年 AS 上映年
      ORDER BY m.上映年 DESC, m.片名
      """
    Then the result should be, in order:
      | 片名           | 上映年 |
      | 流浪地球2      | 2023   |
      | 哪吒之魔童降世 | 2019   |
      | 流浪地球       | 2019   |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用字符串匹配筛选
  # 筛选片名包含特定字符的电影
  # ---------------------------------------------------------------------------
  Scenario: [7] Filter with string pattern matching
    When executing query:
      """
      MATCH (m:电影)
      WHERE m.片名 STARTS WITH '流浪'
      RETURN m.片名 AS 片名, m.上映年 AS 上映年
      ORDER BY m.上映年 DESC
      """
    Then the result should be, in order:
      | 片名      | 上映年 |
      | 流浪地球2 | 2023   |
      | 流浪地球  | 2019   |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 多条件组合筛选（范围 + 类型）
  # 筛选2015年以后上映、豆瓣评分8.5以上的电影
  # ---------------------------------------------------------------------------
  Scenario: [8] Filter with multiple combined conditions
    When executing query:
      """
      MATCH (m:电影)
      WHERE m.上映年 >= 2015 AND m.豆瓣评分 >= 8.5
      RETURN m.片名 AS 片名, m.上映年 AS 上映年, m.豆瓣评分 AS 豆瓣评分
      ORDER BY m.豆瓣评分 DESC
      """
    Then the result should be, in order:
      | 片名       | 上映年 | 豆瓣评分 |
      | 我不是药神 | 2018   | 9.0      |
      | 让子弹飞   | 2010   | 8.9      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用 EXISTS 筛选有特定关系的电影
  # 筛选有获奖记录的电影
  # ---------------------------------------------------------------------------
  Scenario: [9] Filter movies with awards
    When executing query:
      """
      MATCH (m:电影)
      WHERE EXISTS((m)-[:获得奖项]->(:奖项))
      RETURN m.片名 AS 片名
      ORDER BY m.片名
      """
    Then the result should be, in order:
      | 片名       |
      | 我不是药神 |
      | 流浪地球2  |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用 NOT 条件筛选
  # 筛选没有获奖记录的电影
  # ---------------------------------------------------------------------------
  Scenario: [10] Filter movies without awards
    When executing query:
      """
      MATCH (m:电影)
      WHERE NOT EXISTS((m)-[:获得奖项]->(:奖项))
      RETURN m.片名 AS 片名
      ORDER BY m.片名
      """
    Then the result should be, in order:
      | 片名           |
      | 哪吒之魔童降世 |
      | 流浪地球       |
      | 让子弹飞       |
    And no side effects
