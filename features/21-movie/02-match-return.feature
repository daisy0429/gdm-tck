# =============================================================================
# Feature: Movie Scenario - Step 2: MATCH and RETURN Queries
# =============================================================================
# 来源: GDMBASE 电影知识场景教学（初级）第2步
# 目标: 掌握最常用的查询组合 MATCH + RETURN
# 前置条件: 需要完整的电影数据集（由第1步创建）
# =============================================================================

Feature: MovieScenario02 - MATCH and RETURN queries

  Background:
    # 初始化完整的电影数据集
    Given an empty graph
    And having executed:
      """
      CREATE
      (:人物 {姓名:'郭帆', 职业:'导演', 出生年:1980}),
      (:人物 {姓名:'吴京', 职业:'演员', 出生年:1974}),
      (:人物 {姓名:'刘德华', 职业:'演员', 出生年:1961}),
      (:人物 {姓名:'文牧野', 职业:'导演', 出生年:1985}),
      (:人物 {姓名:'徐峥', 职业:'演员', 出生年:1972}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:人物 {姓名:'饺子', 职业:'导演', 出生年:1980}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132}),
      (:电影 {片名:'哪吒之魔童降世', 上映年:2019, 豆瓣评分:8.4, 片长:110}),
      (:类型 {名称:'科幻'}),
      (:类型 {名称:'剧情'}),
      (:类型 {名称:'喜剧'}),
      (:类型 {名称:'动画'}),
      (:国家 {名称:'中国大陆'}),
      (:国家 {名称:'中国香港'}),
      (:奖项 {名称:'金鸡奖最佳故事片', 年份:2023}),
      (:奖项 {名称:'百花奖最佳影片', 年份:2018})
      """
    And having executed:
      """
      MATCH (guo:人物 {姓名:'郭帆'}), (wj:人物 {姓名:'吴京'}), (ldh:人物 {姓名:'刘德华'}),
            (wmy:人物 {姓名:'文牧野'}), (xz:人物 {姓名:'徐峥'}), (jw:人物 {姓名:'姜文'}), (jz:人物 {姓名:'饺子'}),
            (m1:电影 {片名:'流浪地球'}), (m2:电影 {片名:'流浪地球2'}), (m3:电影 {片名:'我不是药神'}),
            (m4:电影 {片名:'让子弹飞'}), (m5:电影 {片名:'哪吒之魔童降世'}),
            (sf:类型 {名称:'科幻'}), (dr:类型 {名称:'剧情'}), (xj:类型 {名称:'喜剧'}), (dh:类型 {名称:'动画'}),
            (cn:国家 {名称:'中国大陆'}), (hk:国家 {名称:'中国香港'}),
            (a1:奖项 {名称:'金鸡奖最佳故事片'}), (a2:奖项 {名称:'百花奖最佳影片'})
      CREATE
      (guo)-[:导演]->(m1),
      (guo)-[:导演]->(m2),
      (wj)-[:参演 {角色:'刘培强'}]->(m1),
      (wj)-[:参演 {角色:'刘培强'}]->(m2),
      (ldh)-[:参演 {角色:'图恒宇'}]->(m2),
      (wmy)-[:导演]->(m3),
      (xz)-[:参演 {角色:'程勇'}]->(m3),
      (jw)-[:导演]->(m4),
      (jw)-[:参演 {角色:'张牧之'}]->(m4),
      (jz)-[:导演]->(m5),
      (m1)-[:属于类型]->(sf),
      (m2)-[:属于类型]->(sf),
      (m3)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(xj),
      (m5)-[:属于类型]->(dh),
      (m1)-[:出品国家]->(cn),
      (m2)-[:出品国家]->(cn),
      (m3)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(hk),
      (m5)-[:出品国家]->(cn),
      (m2)-[:获得奖项]->(a1),
      (m3)-[:获得奖项]->(a2)
      """

  # ---------------------------------------------------------------------------
  # Scenario: 列出全部电影
  # 基础 MATCH + RETURN 查询，按上映年份降序排列
  # ---------------------------------------------------------------------------
  Scenario: [1] List all movies ordered by release year
    When executing query:
      """
      MATCH (m:电影)
      RETURN m.片名 AS 片名, m.上映年 AS 上映年, m.豆瓣评分 AS 豆瓣评分
      ORDER BY m.上映年 DESC
      """
    Then the result should be, in order:
      | 片名           | 上映年 | 豆瓣评分 |
      | 流浪地球2      | 2023   | 8.3      |
      | 哪吒之魔童降世 | 2019   | 8.4      |
      | 流浪地球       | 2019   | 7.9      |
      | 我不是药神     | 2018   | 9.0      |
      | 让子弹飞       | 2010   | 8.9      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询某部电影的导演
  # 通过 (:电影 {片名:'流浪地球2'}) 精确定位一部电影，再匹配 -[:导演]-> 关系
  # ---------------------------------------------------------------------------
  Scenario: [2] Query director of a specific movie
    When executing query:
      """
      MATCH (p:人物)-[:导演]->(m:电影 {片名:'流浪地球2'})
      RETURN m.片名 AS 电影, p.姓名 AS 导演
      """
    Then the result should be, in any order:
      | 电影      | 导演   |
      | 流浪地球2 | 郭帆   |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询某部电影的演员和角色
  # 把关系命名为 r，读取关系属性 r.角色
  # "谁演了谁"的信息存放在关系上，而不是人物节点上
  # ---------------------------------------------------------------------------
  Scenario: [3] Query actors and roles of a specific movie
    When executing query:
      """
      MATCH (p:人物)-[r:参演]->(m:电影 {片名:'流浪地球2'})
      RETURN m.片名 AS 电影, p.姓名 AS 演员, r.角色 AS 角色名
      """
    Then the result should be, in any order:
      | 电影      | 演员   | 角色名   |
      | 流浪地球2 | 吴京   | 刘培强   |
      | 流浪地球2 | 刘德华 | 图恒宇   |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 从人物反查其参与的电影
  # [r:参演|导演] 同时匹配两种参与方式
  # type(r) 在结果中标出具体命中的关系类型
  # ---------------------------------------------------------------------------
  Scenario: [4] Query movies participated by a person
    When executing query:
      """
      MATCH (p:人物 {姓名:'吴京'})-[r:参演|导演]->(m:电影)
      RETURN p.姓名 AS 姓名, type(r) AS 参与方式, m.片名 AS 电影
      ORDER BY m.上映年
      """
    Then the result should be, in order:
      | 姓名 | 参与方式 | 电影      |
      | 吴京 | 参演     | 流浪地球  |
      | 吴京 | 参演     | 流浪地球2 |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询姜文参与的电影（既导演又参演）
  # ---------------------------------------------------------------------------
  Scenario: [5] Query movies of a director-actor
    When executing query:
      """
      MATCH (p:人物 {姓名:'姜文'})-[r:参演|导演]->(m:电影)
      RETURN p.姓名 AS 姓名, type(r) AS 参与方式, m.片名 AS 电影
      ORDER BY m.上映年
      """
    Then the result should be, in order:
      | 姓名 | 参与方式 | 电影     |
      | 姜文 | 导演     | 让子弹飞 |
      | 姜文 | 参演     | 让子弹飞 |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询电影详情页所需的核心信息
  # 综合查询：电影基本信息 + 导演 + 演员列表
  # ---------------------------------------------------------------------------
  Scenario: [6] Query movie detail page information
    When executing query:
      """
      MATCH (m:电影 {片名:'流浪地球'})
      OPTIONAL MATCH (d:人物)-[:导演]->(m)
      OPTIONAL MATCH (a:人物)-[r:参演]->(m)
      RETURN m.片名 AS 片名, m.上映年 AS 上映年, m.豆瓣评分 AS 豆瓣评分,
             collect(DISTINCT d.姓名) AS 导演列表,
             collect(DISTINCT {演员:a.姓名, 角色:r.角色}) AS 演员列表
      """
    Then the result should be, in any order:
      | 片名     | 上映年 | 豆瓣评分 | 导演列表 | 演员列表                                    |
      | 流浪地球 | 2019   | 7.9      | ['郭帆'] | [{'演员':'吴京', '角色':'刘培强'}]         |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询所有导演及其作品列表
  # ---------------------------------------------------------------------------
  Scenario: [7] Query all directors and their filmographies
    When executing query:
      """
      MATCH (p:人物)-[:导演]->(m:电影)
      WITH p, collect(m.片名) AS 作品列表
      RETURN p.姓名 AS 导演, 作品列表
      ORDER BY p.姓名
      """
    Then the result should be, in order:
      | 导演   | 作品列表                          |
      | 姜文   | ['让子弹飞']                      |
      | 郭帆   | ['流浪地球', '流浪地球2']         |
      | 饺子   | ['哪吒之魔童降世']                |
      | 文牧野 | ['我不是药神']                    |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 查询电影的基本属性
  # 使用 RETURN 直接返回节点属性
  # ---------------------------------------------------------------------------
  Scenario: [8] Query movie basic properties
    When executing query:
      """
      MATCH (m:电影 {片名:'我不是药神'})
      RETURN m.片名 AS 片名, m.上映年 AS 上映年, m.豆瓣评分 AS 豆瓣评分, m.片长 AS 片长
      """
    Then the result should be, in any order:
      | 片名       | 上映年 | 豆瓣评分 | 片长 |
      | 我不是药神 | 2018   | 9.0      | 117  |
    And no side effects
