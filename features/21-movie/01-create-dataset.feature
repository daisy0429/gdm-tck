  Scenario: [7] Create movie-country relationships
    Given having executed:
      """
      CREATE
      (:国家 {名称:'中国大陆'}), (:国家 {名称:'中国香港'}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
