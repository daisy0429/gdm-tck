#encoding: utf-8

# =============================================================================
# Feature: Movie Scenario - Step 1: Create Movie Dataset
# =============================================================================
# 来源: GDMBASE 电影知识场景教学（初级）第1步
# 目标: 在 default 图空间中创建"电影知识图谱"的基础数据
# 说明: 由于 bolt 协议暂不支持创建 graph，本测试使用 default 图空间
#       每个 scenario 开始前清空图数据，确保测试隔离性
# =============================================================================

Feature: MovieScenario01 - Create movie dataset

  Background:
    # 每个场景开始前清空图，确保数据隔离
    Given an empty graph

  # ---------------------------------------------------------------------------
  # Scenario: 创建人物顶点
  # 创建7位电影人物（导演/演员）
  # ---------------------------------------------------------------------------
  Scenario: [1] Create person nodes
    When executing query:
      """
      CREATE
      (:人物 {姓名:'郭帆', 职业:'导演', 出生年:1980}),
      (:人物 {姓名:'吴京', 职业:'演员', 出生年:1974}),
      (:人物 {姓名:'刘德华', 职业:'演员', 出生年:1961}),
      (:人物 {姓名:'文牧野', 职业:'导演', 出生年:1985}),
      (:人物 {姓名:'徐峥', 职业:'演员', 出生年:1972}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:人物 {姓名:'饺子', 职业:'导演', 出生年:1980})
      """
    Then the result should be empty
    And no side effects
    When executing query:
      """
      MATCH (p:人物) RETURN p.姓名 AS 姓名 ORDER BY p.出生年
      """
    Then the result should be, in order:
      | 姓名   |
      | 刘德华 |
      | 姜文   |
      | 吴京   |
      | 徐峥   |
      | 郭帆   |
      | 饺子   |
      | 文牧野 |

  # ---------------------------------------------------------------------------
  # Scenario: 创建电影顶点
  # 创建5部电影节点
  # ---------------------------------------------------------------------------
  Scenario: [2] Create movie nodes
    When executing query:
      """
      CREATE
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132}),
      (:电影 {片名:'哪吒之魔童降世', 上映年:2019, 豆瓣评分:8.4, 片长:110})
      """
    Then the result should be empty
    And no side effects
    When executing query:
      """
      MATCH (m:电影) RETURN m.片名 AS 片名 ORDER BY m.上映年 DESC
      """
    Then the result should be, in order:
      | 片名           |
      | 流浪地球2      |
      | 哪吒之魔童降世 |
      | 流浪地球       |
      | 我不是药神     |
      | 让子弹飞       |

  # ---------------------------------------------------------------------------
  # Scenario: 创建类型、国家、奖项顶点
  # ---------------------------------------------------------------------------
  Scenario: [3] Create genre, country and award nodes
    When executing query:
      """
      CREATE
      (:类型 {名称:'科幻'}),
      (:类型 {名称:'剧情'}),
      (:类型 {名称:'喜剧'}),
      (:类型 {名称:'动画'}),
      (:国家 {名称:'中国大陆'}),
      (:国家 {名称:'中国香港'}),
      (:奖项 {名称:'金鸡奖最佳故事片', 年份:2023}),
      (:奖项 {名称:'百花奖最佳影片', 年份:2018})
      """
    Then the result should be empty
    And no side effects
    When executing query:
      """
      MATCH (g:类型) RETURN g.名称 AS 类型 ORDER BY g.名称
      """
    Then the result should be, in order:
      | 类型 |
      | 动画 |
      | 喜剧 |
      | 剧情 |
      | 科幻 |

  # ---------------------------------------------------------------------------
  # Scenario: 创建导演关系
  # 郭帆导演《流浪地球》《流浪地球2》
  # 文牧野导演《我不是药神》
  # 姜文导演《让子弹飞》
  # 饺子导演《哪吒之魔童降世》
  # ---------------------------------------------------------------------------
  Scenario: [4] Create director relationships
    Given having executed:
      """
      CREATE
      (:人物 {姓名:'郭帆', 职业:'导演', 出生年:1980}),
      (:人物 {姓名:'文牧野', 职业:'导演', 出生年:1985}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:人物 {姓名:'饺子', 职业:'导演', 出生年:1980}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132}),
      (:电影 {片名:'哪吒之魔童降世', 上映年:2019, 豆瓣评分:8.4, 片长:110})
      """
    When executing query:
      """
      MATCH (guo:人物 {姓名:'郭帆'}), (wmy:人物 {姓名:'文牧野'}),
            (jw:人物 {姓名:'姜文'}), (jz:人物 {姓名:'饺子'}),
            (m1:电影 {片名:'流浪地球'}), (m2:电影 {片名:'流浪地球2'}),
            (m3:电影 {片名:'我不是药神'}), (m4:电影 {片名:'让子弹飞'}),
            (m5:电影 {片名:'哪吒之魔童降世'})
      CREATE
      (guo)-[:导演]->(m1),
      (guo)-[:导演]->(m2),
      (wmy)-[:导演]->(m3),
      (jw)-[:导演]->(m4),
      (jz)-[:导演]->(m5)
      """
    Then the result should be empty
    And no side effects
    When executing query:
      """
      MATCH (p:人物)-[:导演]->(m:电影)
      RETURN p.姓名 AS 导演, m.片名 AS 电影
      ORDER BY 导演, 电影
      """
    Then the result should be, in order:
      | 导演   | 电影           |
      | 姜文   | 让子弹飞       |
      | 郭帆   | 流浪地球       |
      | 郭帆   | 流浪地球2      |
      | 饺子   | 哪吒之魔童降世 |
      | 文牧野 | 我不是药神     |

  # ---------------------------------------------------------------------------
  # Scenario: 创建参演关系（带角色属性）
  # ---------------------------------------------------------------------------
  Scenario: [5] Create actor relationships with roles
    Given having executed:
      """
      CREATE
      (:人物 {姓名:'吴京', 职业:'演员', 出生年:1974}),
      (:人物 {姓名:'刘德华', 职业:'演员', 出生年:1961}),
      (:人物 {姓名:'徐峥', 职业:'演员', 出生年:1972}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132})
      """
    When executing query:
      """
      MATCH (wj:人物 {姓名:'吴京'}), (ldh:人物 {姓名:'刘德华'}),
            (xz:人物 {姓名:'徐峥'}), (jw:人物 {姓名:'姜文'}),
            (m1:电影 {片名:'流浪地球'}), (m2:电影 {片名:'流浪地球2'}),
            (m3:电影 {片名:'我不是药神'}), (m4:电影 {片名:'让子弹飞'})
      CREATE
      (wj)-[:参演 {角色:'刘培强'}]->(m1),
      (wj)-[:参演 {角色:'刘培强'}]->(m2),
      (ldh)-[:参演 {角色:'图恒宇'}]->(m2),
      (xz)-[:参演 {角色:'程勇'}]->(m3),
      (jw)-[:参演 {角色:'张牧之'}]->(m4)
      """
    Then the result should be empty
    And no side effects
    When executing query:
      """
      MATCH (p:人物)-[r:参演]->(m:电影)
      RETURN p.姓名 AS 演员, r.角色 AS 角色, m.片名 AS 电影
      ORDER BY 演员, 电影
      """
    Then the result should be, in order:
      | 演员   | 角色     | 电影       |
      | 姜文   | 张牧之   | 让子弹飞   |
      | 刘德华 | 图恒宇   | 流浪地球2  |
      | 吴京   | 刘培强   | 流浪地球   |
      | 吴京   | 刘培强   | 流浪地球2  |
      | 徐峥   | 程勇     | 我不是药神 |

