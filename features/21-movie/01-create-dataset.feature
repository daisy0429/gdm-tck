  Scenario: [8] Create movie-award relationships
    Given having executed:
      """
      CREATE
      (:奖项 {名称:'金鸡奖最佳故事片', 年份:2023}),
      (:奖项 {名称:'百花奖最佳影片', 年份:2018}),
