#encoding: utf-8

# =============================================================================
# Feature: Movie Scenario - Step 4: WITH Aggregation Statistics
# =============================================================================
# 来源: GDMBASE 电影知识场景教学（初级）第4步
# 目标: 学会在电影场景中做统计查询
# 前置条件: 需要完整的电影数据集
# =============================================================================

Feature: MovieScenario04 - WITH aggregation statistics

  Background:
    # 初始化完整的电影数据集
    Given an empty graph
    And having executed:
      """
      CREATE
      (:人物 {姓名:'郭帆', 职业:'导演', 出生年:1980}),
      (:人物 {姓名:'吴京', 职业:'演员', 出生年:1974}),
      (:人物 {姓名:'刘德华', 职业:'演员', 出生年:1961}),
      (:人物 {姓名:'文牧野', 职业:'导演', 出生年:1985}),
      (:人物 {姓名:'徐峥', 职业:'演员', 出生年:1972}),
      (:人物 {姓名:'姜文', 职业:'导演', 出生年:1963}),
      (:人物 {姓名:'饺子', 职业:'导演', 出生年:1980}),
      (:电影 {片名:'流浪地球', 上映年:2019, 豆瓣评分:7.9, 片长:125}),
      (:电影 {片名:'流浪地球2', 上映年:2023, 豆瓣评分:8.3, 片长:173}),
      (:电影 {片名:'我不是药神', 上映年:2018, 豆瓣评分:9.0, 片长:117}),
      (:电影 {片名:'让子弹飞', 上映年:2010, 豆瓣评分:8.9, 片长:132}),
      (:电影 {片名:'哪吒之魔童降世', 上映年:2019, 豆瓣评分:8.4, 片长:110}),
      (:类型 {名称:'科幻'}),
      (:类型 {名称:'剧情'}),
      (:类型 {名称:'喜剧'}),
      (:类型 {名称:'动画'}),
      (:国家 {名称:'中国大陆'}),
      (:国家 {名称:'中国香港'}),
      (:奖项 {名称:'金鸡奖最佳故事片', 年份:2023}),
      (:奖项 {名称:'百花奖最佳影片', 年份:2018})
      """
    And having executed:
      """
      MATCH (guo:人物 {姓名:'郭帆'}), (wj:人物 {姓名:'吴京'}), (ldh:人物 {姓名:'刘德华'}),
            (wmy:人物 {姓名:'文牧野'}), (xz:人物 {姓名:'徐峥'}), (jw:人物 {姓名:'姜文'}), (jz:人物 {姓名:'饺子'}),
            (m1:电影 {片名:'流浪地球'}), (m2:电影 {片名:'流浪地球2'}), (m3:电影 {片名:'我不是药神'}),
            (m4:电影 {片名:'让子弹飞'}), (m5:电影 {片名:'哪吒之魔童降世'}),
            (sf:类型 {名称:'科幻'}), (dr:类型 {名称:'剧情'}), (xj:类型 {名称:'喜剧'}), (dh:类型 {名称:'动画'}),
            (cn:国家 {名称:'中国大陆'}), (hk:国家 {名称:'中国香港'}),
            (a1:奖项 {名称:'金鸡奖最佳故事片'}), (a2:奖项 {名称:'百花奖最佳影片'})
      CREATE
      (guo)-[:导演]->(m1),
      (guo)-[:导演]->(m2),
      (wj)-[:参演 {角色:'刘培强'}]->(m1),
      (wj)-[:参演 {角色:'刘培强'}]->(m2),
      (ldh)-[:参演 {角色:'图恒宇'}]->(m2),
      (wmy)-[:导演]->(m3),
      (xz)-[:参演 {角色:'程勇'}]->(m3),
      (jw)-[:导演]->(m4),
      (jw)-[:参演 {角色:'张牧之'}]->(m4),
      (jz)-[:导演]->(m5),
      (m1)-[:属于类型]->(sf),
      (m2)-[:属于类型]->(sf),
      (m3)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(dr),
      (m4)-[:属于类型]->(xj),
      (m5)-[:属于类型]->(dh),
      (m1)-[:出品国家]->(cn),
      (m2)-[:出品国家]->(cn),
      (m3)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(cn),
      (m4)-[:出品国家]->(hk),
      (m5)-[:出品国家]->(cn),
      (m2)-[:获得奖项]->(a1),
      (m3)-[:获得奖项]->(a2)
      """

  # ---------------------------------------------------------------------------
  # Scenario: 统计每位导演执导的电影数
  # WITH p, count(m) 按导演 p 分组，对每组电影做计数
  # ---------------------------------------------------------------------------
  Scenario: [1] Count movies directed by each director
    When executing query:
      """
      MATCH (p:人物)-[:导演]->(m:电影)
      WITH p, count(m) AS 作品数
      RETURN p.姓名 AS 导演, 作品数
      ORDER BY 作品数 DESC, 导演
      """
    Then the result should be, in order:
      | 导演   | 作品数 |
      | 郭帆   | 2      |
      | 姜文   | 1      |
      | 文牧野 | 1      |
      | 饺子   | 1      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 统计每种类型的电影数量和平均评分
  # 一次聚合多个指标：count(m) + avg(m.豆瓣评分)
  # ---------------------------------------------------------------------------
  Scenario: [2] Count movies and average rating by genre
    When executing query:
      """
      MATCH (m:电影)-[:属于类型]->(g:类型)
      WITH g, count(m) AS 电影数, avg(m.豆瓣评分) AS 平均评分
      RETURN g.名称 AS 类型, 电影数, 平均评分
      ORDER BY 平均评分 DESC
      """
    Then the result should be, in order:
      | 类型 | 电影数 | 平均评分 |
      | 剧情 | 2      | 8.95     |
      | 喜剧 | 1      | 8.9      |
      | 科幻 | 2      | 8.1      |
      | 动画 | 1      | 8.4      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 找出演员参与电影数 Top 3
  # ORDER BY + LIMIT 用于 TopN 排名
  # ---------------------------------------------------------------------------
  Scenario: [3] Find top 3 actors by movie count
    When executing query:
      """
      MATCH (p:人物)-[:参演]->(m:电影)
      WITH p, count(m) AS 参演数
      ORDER BY 参演数 DESC, p.姓名
      LIMIT 3
      RETURN p.姓名 AS 演员, 参演数
      """
    Then the result should be, in order:
      | 演员   | 参演数 |
      | 吴京   | 2      |
      | 姜文   | 1      |
      | 刘德华 | 1      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 筛选"至少执导2部电影"的导演
  # 聚合后过滤：WHERE 导演片数 >= 2 过滤的是统计结果
  # ---------------------------------------------------------------------------
  Scenario: [4] Filter directors with at least 2 movies
    When executing query:
      """
      MATCH (p:人物)-[:导演]->(m:电影)
      WITH p, count(m) AS 导演片数
      WHERE 导演片数 >= 2
      RETURN p.姓名 AS 导演, 导演片数
      """
    Then the result should be, in any order:
      | 导演 | 导演片数 |
      | 郭帆 | 2        |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 统计每年的电影上映数量
  # ---------------------------------------------------------------------------
  Scenario: [5] Count movies by release year
    When executing query:
      """
      MATCH (m:电影)
      WITH m.上映年 AS 年份, count(m) AS 电影数
      RETURN 年份, 电影数
      ORDER BY 年份 DESC
      """
    Then the result should be, in order:
      | 年份 | 电影数 |
      | 2023 | 1      |
      | 2019 | 2      |
      | 2018 | 1      |
      | 2010 | 1      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 统计每位演员参演的电影平均评分
  # ---------------------------------------------------------------------------
  Scenario: [6] Calculate average rating of movies per actor
    When executing query:
      """
      MATCH (p:人物)-[:参演]->(m:电影)
      WITH p, count(m) AS 参演数, avg(m.豆瓣评分) AS 平均评分
      RETURN p.姓名 AS 演员, 参演数, 平均评分
      ORDER BY 平均评分 DESC
      """
    Then the result should be, in order:
      | 演员   | 参演数 | 平均评分 |
      | 徐峥   | 1      | 9.0      |
      | 姜文   | 1      | 8.9      |
      | 刘德华 | 1      | 8.3      |
      | 吴京   | 2      | 8.1      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 统计每个国家的电影数量
  # ---------------------------------------------------------------------------
  Scenario: [7] Count movies by country
    When executing query:
      """
      MATCH (m:电影)-[:出品国家]->(c:国家)
      WITH c, count(m) AS 电影数
      RETURN c.名称 AS 国家, 电影数
      ORDER BY 电影数 DESC
      """
    Then the result should be, in order:
      | 国家     | 电影数 |
      | 中国大陆 | 5      |
      | 中国香港 | 1      |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 统计有获奖记录的电影数量
  # ---------------------------------------------------------------------------
  Scenario: [8] Count awarded movies
    When executing query:
      """
      MATCH (m:电影)-[:获得奖项]->(a:奖项)
      WITH count(DISTINCT m) AS 获奖电影数
      RETURN 获奖电影数
      """
    Then the result should be, in any order:
      | 获奖电影数 |
      | 2          |
    And no side effects

  # ---------------------------------------------------------------------------
  # Scenario: 使用多个 WITH 做链式聚合
  # 先按类型分组统计，再筛选电影数大于1的类型
  # ---------------------------------------------------------------------------
  Scenario: [9] Chain multiple WITH clauses for complex aggregation
    When executing query:
      """
      MATCH (m:电影)-[:属于类型]->(g:类型)
      WITH g, count(m) AS 电影数
      WHERE 电影数 > 1
      WITH g.名称 AS 类型, 电影数
      RETURN 类型, 电影数
      ORDER BY 电影数 DESC
      """
    Then the result should be, in order:
      | 类型 | 电影数 |
      | 科幻 | 2      |
      | 剧情 | 2      |
    And no side effects
